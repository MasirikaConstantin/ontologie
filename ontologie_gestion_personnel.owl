<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/ontologie/gestion-personnel#"
     xml:base="http://example.org/ontologie/gestion-personnel"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://example.org/ontologie/gestion-personnel">
        <rdfs:label xml:lang="fr">Ontologie OWL pour la gestion du personnel</rdfs:label>
        <rdfs:comment xml:lang="fr">Modèle conceptuel pour représenter les employés, départements, postes, contrats, compétences, formations, absences et évaluations RH.</rdfs:comment>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>

    <!-- Classes principales -->
    <owl:Class rdf:about="#Personne">
        <rdfs:label xml:lang="fr">Personne</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="#Employe">
        <rdfs:subClassOf rdf:resource="#Personne"/>
        <rdfs:label xml:lang="fr">Employé</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="#Manager">
        <rdfs:subClassOf rdf:resource="#Employe"/>
        <rdfs:label xml:lang="fr">Manager</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="#Departement">
        <rdfs:label xml:lang="fr">Département</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="#Poste">
        <rdfs:label xml:lang="fr">Poste</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="#Contrat">
        <rdfs:label xml:lang="fr">Contrat</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="#Competence">
        <rdfs:label xml:lang="fr">Compétence</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="#Formation">
        <rdfs:label xml:lang="fr">Formation</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="#Absence">
        <rdfs:label xml:lang="fr">Absence</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="#Evaluation">
        <rdfs:label xml:lang="fr">Évaluation</rdfs:label>
    </owl:Class>

    <!-- Hiérarchie RH -->
    <owl:ObjectProperty rdf:about="#travailleDans">
        <rdfs:domain rdf:resource="#Employe"/>
        <rdfs:range rdf:resource="#Departement"/>
        <rdfs:label xml:lang="fr">travaille dans</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#occupePoste">
        <rdfs:domain rdf:resource="#Employe"/>
        <rdfs:range rdf:resource="#Poste"/>
        <rdfs:label xml:lang="fr">occupe le poste</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#aContrat">
        <rdfs:domain rdf:resource="#Employe"/>
        <rdfs:range rdf:resource="#Contrat"/>
        <rdfs:label xml:lang="fr">a pour contrat</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#supervise">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="#Manager"/>
        <rdfs:range rdf:resource="#Employe"/>
        <rdfs:label xml:lang="fr">supervise</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#estSupervisePar">
        <owl:inverseOf rdf:resource="#supervise"/>
        <rdfs:domain rdf:resource="#Employe"/>
        <rdfs:range rdf:resource="#Manager"/>
        <rdfs:label xml:lang="fr">est supervisé par</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#possedeCompetence">
        <rdfs:domain rdf:resource="#Employe"/>
        <rdfs:range rdf:resource="#Competence"/>
        <rdfs:label xml:lang="fr">possède la compétence</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#suitFormation">
        <rdfs:domain rdf:resource="#Employe"/>
        <rdfs:range rdf:resource="#Formation"/>
        <rdfs:label xml:lang="fr">suit la formation</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#aAbsence">
        <rdfs:domain rdf:resource="#Employe"/>
        <rdfs:range rdf:resource="#Absence"/>
        <rdfs:label xml:lang="fr">a une absence</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#aEvaluation">
        <rdfs:domain rdf:resource="#Employe"/>
        <rdfs:range rdf:resource="#Evaluation"/>
        <rdfs:label xml:lang="fr">a une évaluation</rdfs:label>
    </owl:ObjectProperty>

    <!-- Propriétés de données -->
    <owl:DatatypeProperty rdf:about="#matricule">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="#Employe"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="fr">matricule</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#nom">
        <rdfs:domain rdf:resource="#Personne"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="fr">nom</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#prenom">
        <rdfs:domain rdf:resource="#Personne"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="fr">prénom</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#email">
        <rdfs:domain rdf:resource="#Personne"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="fr">adresse e-mail</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#dateEmbauche">
        <rdfs:domain rdf:resource="#Employe"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label xml:lang="fr">date d'embauche</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#intitule">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="fr">intitulé</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#dateDebut">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label xml:lang="fr">date de début</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#dateFin">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label xml:lang="fr">date de fin</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#noteEvaluation">
        <rdfs:domain rdf:resource="#Evaluation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="fr">note d'évaluation</rdfs:label>
    </owl:DatatypeProperty>

    <!-- Contraintes -->
    <owl:Class rdf:about="#Employe">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#matricule"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#travailleDans"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="#Departement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#occupePoste"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="#Poste"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- Exemples d'individus -->
    <owl:NamedIndividual rdf:about="#DepartementRH">
        <rdf:type rdf:resource="#Departement"/>
        <intitule>Ressources humaines</intitule>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#PosteResponsableRH">
        <rdf:type rdf:resource="#Poste"/>
        <intitule>Responsable RH</intitule>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#CompetenceRecrutement">
        <rdf:type rdf:resource="#Competence"/>
        <intitule>Recrutement</intitule>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#EmployeExemple">
        <rdf:type rdf:resource="#Manager"/>
        <matricule>EMP-001</matricule>
        <nom>Diallo</nom>
        <prenom>Amina</prenom>
        <email>amina.diallo@example.org</email>
        <dateEmbauche rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-15</dateEmbauche>
        <travailleDans rdf:resource="#DepartementRH"/>
        <occupePoste rdf:resource="#PosteResponsableRH"/>
        <possedeCompetence rdf:resource="#CompetenceRecrutement"/>
    </owl:NamedIndividual>
</rdf:RDF>
